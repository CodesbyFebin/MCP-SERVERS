# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_BASE_URL: Canonical production origin used for sitemap, robots and schema URLs.
NEXT_PUBLIC_BASE_URL="https://www.mcpserver.in"

# NEXT_PUBLIC_GA4_MEASUREMENT_ID: Google Analytics 4 Measurement ID (e.g., G-XXXXXXXXXX).
# Leave empty to disable GA4 tracking.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""

# NEXT_PUBLIC_GTM_ID: Google Tag Manager container ID (e.g., GTM-XXXXXXX).
# Leave empty to disable GTM.
NEXT_PUBLIC_GTM_ID=""

# POSTGRES_URL: Provided automatically by Vercel once a Postgres store (Storage tab)
# is created and connected to this project. Required for /api/auth/* to work.
# Locally: run `vercel env pull .env.local` after connecting the store, or point at
# any Postgres instance and run db/schema.sql against it once.
POSTGRES_URL=""

# SESSION_SECRET: random 32+ byte secret used to sign auth session cookies (jose/HS256).
# Generate with: openssl rand -base64 32
SESSION_SECRET=""

# GITHUB_TOKEN: optional, used by scripts/extract-content-gaps.mjs to raise the
# GitHub search rate limit from 10 req/min to 30 req/min. No scopes required.
GITHUB_TOKEN=""

# REDDIT_CLIENT_ID / REDDIT_CLIENT_SECRET: optional, used by
# scripts/extract-content-gaps.mjs for Reddit search. Reddit's public JSON
# endpoint 403s from most server IPs, so a free "script" app is required:
# https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# GOOGLE_SITE_VERIFICATION / YANDEX_SITE_VERIFICATION / BING_SITE_VERIFICATION:
# optional search-console ownership verification tokens, rendered as meta tags
# in app/layout.tsx when set. Get real values from each console; leave unset
# to omit the tag entirely rather than ship a placeholder.
GOOGLE_SITE_VERIFICATION=""
YANDEX_SITE_VERIFICATION=""
BING_SITE_VERIFICATION=""
